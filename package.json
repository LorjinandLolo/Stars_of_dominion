{
  "name": "stars-dominion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --webpack",
    "dev:lan": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --webpack -H 0.0.0.0",
    "build": "node --max-old-space-size=8192 node_modules/next/dist/bin/next build",
    "start": "node --max-old-space-size=8192 node_modules/next/dist/bin/next start",
    "lint": "next lint",
    "import:data": "npx tsx scripts/importData.ts",
    "worker": "npx tsx scripts/game-loop.ts",
    "setup:duel": "npx tsx scripts/setup-dev-duel.ts",
    "db:up": "docker compose up -d",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.27",
    "better-auth": "^1.6.23",
    "clsx": "^2.1.1",
    "lucide-react": "^0.378.0",
    "next": "^16.2.1",
    "pg": "^8.22.0",
    "react": "^19",
    "react-dom": "^19",
    "swr": "^2.2.5",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.1",
    "jest": "^29.7.0",
    "postcss": "^8.5.8",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  }
